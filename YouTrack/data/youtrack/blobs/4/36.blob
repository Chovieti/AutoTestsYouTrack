table__group" ng-repeat="group in report.data.groups">\n      <tr ng-if="timeReportCtrl.hasGroups()" class="yt-table__row">\n        <td colspan="{{timeReportCtrl.getGroupColSpan()}}" class="yt-table__cell yt-table__group__title">\n          <yt-report-group group="group"></yt-report-group>\n        </td>\n        <td class="yt-table__cell yt-table__cell_progress-bar" ng-if="timeReportCtrl.isShowGroupEstimation()">\n          &nbsp;\n        </td>\n        <td class="yt-table__cell time-report__value yt-bold">\n          <yt-period-value value-presentation="group.estimation" show-zero="false"></yt-period-value>\n        </td>\n        <td class="yt-table__cell time-report__value yt-bold">\n          <yt-period-value value-presentation="group.duration" show-zero="false"></yt-period-value>\n        </td>\n      </tr>\n\n      <tr\n        ng-if="!timeReportCtrl.hasGroups() || timeReportCtrl.isDetailedView"\n        ng-repeat="line in timeReportCtrl.lines[group.name]"\n        class="yt-table__row"\n      >\n        <td class="yt-table__cell yt-table_time__id" ng-if="!id.perUser">\n          <a class="ring-link" ng-if="line.firstInSubGroup" target="_blank"\n             ng-href="{{timeReportCtrl.getIssueUrl(line)}}">{{line.issueId}}</a>\n        </td>\n\n        <td class="yt-table__cell yt-table_time__id" ng-if="id.perUser">\n          <a class="ring-link" ng-if="line.firstInSubGroup" target="_blank"\n             ng-href="{{timeReportCtrl.getUserUrl(line)}}">\n            <rg-avatar\n              size="16"\n              url="line.userAvatarUrl"\n            ></rg-avatar>\n          </a>\n        </td>\n\n        <td class="yt-table__cell">\n          <span ng-if="line.firstInSubGroup">{{line.description}}</span>\n        </td>\n\n        <td class="yt-table__cell yt-table__cell_progress-bar" ng-if="timeReportCtrl.isShowGroupEstimation()">\n          <yt-report-time-progress progress="line.periods.totalSpentTime"\n                                   estimation="line.periods.estimation"\n                                   ng-if="timeReportCtrl.isShowLinesEstimation() && line.periods.estimation && line.periods.estimation.value">\n          </yt-report-time-progress>\n        </td>\n\n        <td class="yt-table__cell time-report__value">\n          <span ng-if="line.firstInSubGroup">\n            <yt-period-value value-presentation="line.periods.estimation" show-zero="false"></yt-period-value>\n          </span>\n        </td>\n        <td class="yt-table__cell time-report__value">\n          <yt-period-value value-presentation="line.periods.timeSpent"></yt-period-value>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n\n</div>\n')}]),e.exports=t},8107:e=>{var t="youtrack-report__title.html";window.angular.module("widget.youtrackDashboard.report").run(["$templateCache",function(e){e.put(t,'\x3c!--\n<div ng-if="report.parameters">\n    <div class="report__query">\n        <span ng-repeat="project in report.parameters.projects"\n              class="report__query__i">{{project.name}}</span><span class="report__query__i">{{report.parameters.query | mayBeEmpty}}</span>\n    </div>\n</div>--\x3e\n')}]),e.exports=t},9985:e=>{var t="youtrack-report__verified-distribution/youtrack-report__verified-distribution.html";window.angular.module("widget.youtrackDashboard.report").run(["$templateCache",function(e){e.put(t,'<div ng-if="report && report.data" ng-include="\'youtrack-report__simple-bars-widget/youtrack-report__simple-bars-widget.html\'"></div>\n')}]),e.exports=t},6639:e=>{var t="youtrack-report__verify-rate/youtrack-report__verify-rate.html";window.angular.module("widget.youtrackDashboard.report").run(["$templateCache",function(e){e.put(t,'<div ng-if="report && report.data"\n     class="youtrack-report__subcontainer"\n     ng-include="\'youtrack-report__rate-widget/youtrack-report__rate-widget.html\'"></div>\n')}]),e.exports=t},7711:e=>{var t="youtrack-report__x-axis.html";window.angular.module("widget.youtrackDashboard.report"