/**
 * Legacy "Star as a tag" workflow compatibility shim (JT-93775).
 *
 * Decorates an `issue.tags` iterable so JS code written against the legacy contract
 * (where the per-user "Star" tag lived in `issue.tags`) keeps working after the
 * Star migration to a dedicated `XdStarWatchFolder` entity (YTB-2375).
 *
 * For each user that has starred the issue, the shim surfaces a synthetic tag
 * `{name: 'Star', owner: <real user wrapper>}` from `issue.tags.forEach/find/map/...`.
 * Writes against synthetic stars (`tags.add(s)` / `tags.delete(s)`) are routed to
 * the new model via `issue.star(user)` / `issue.unstar(user)`.
 *
 * The whole module is inert when the `legacyStarTagWorkflowShim` feature flag is off.
 *
 * To delete this shim at R+2:
 *   - remove this file
 *   - remove the marked block in `entities.js` (one require + one call site in
 *     `createMutableIterableWW`)
 *   - remove the Kotlin side (`youtrack-workflow/.../legacystar/*`) and the
 *     whitelisted classes in `WorkflowClassShutter`.
 */

const LegacyStarShim = Java.type('jetbrains.youtrack.workflow.legacystar.LegacyStarShimRuntime');
const SYNTHETIC_STAR_MARKER = '$$isLegacyStarShim';

/**
 * A frozen, empty, immutable-Set-shaped stub that satisfies the ImmutableIterableWW interface.
 * Used as the value of all Set-typed WatchFolder / IssueTag fields on synthetic star objects
 * so that code like `tag.permittedUpdateUserGroups.has(x)` returns false instead of throwing.
 */
const EMPTY_SET = (function () {
  const DONE = {done: true, value: null};
  const emptyIter = {next: function () { return DONE; }};
  const s = {
    size: 0,
    first: function () { return undefined; },
    last: function () { return undefined; },
    isEmpty: function () { return true; },
    isNotEmpty: function () { return false; },
    get: function () { return undefined; },
    has: function () { return false; },
    find: function () { return undefined; },
    forEach: function () {},
    map: function () { return []; },
    slice: function () { return []; },
    entries: function () { return emptyIter; },
    values: function () { return emptyIter; },
    '@@iterator': function () { return emptyIter; },
    isChanged: false,
    toString: function () { return '[]'; }
  };
  s.added = s;
  s.removed = s;
  return s;
}());

let entitiesRegistry = null;

/**
 * Wire the registry once at entities.js load time so the shim can construct
 * user wrappers via the same constructor table the rest of the JS API uses.
 */
exports.init = function (entities) {
  entitiesRegistry = entities;
};

/**
 * The four dynamically registered API methods the shim wraps post-registration. Used by
 * entities.js's `handleStaticMethod` / `handleMethod` to relax `Object.defineProperty`
 * flags *only* for these entries â€” every other dynamically registered method stays
 * non-configurable / non-writable as before.
 */
const OVERRIDABLE_METHODS = {
  static: {
    Tag: ['findByName', 'findTagByName']
  },
  instance: {
    Issue: ['tag', 'untag', 'hasTag', 'addTag']
  }
};

exports.shouldBeOverridable = function (typeName, isStatic, memberName) {
  const cfg = (isStatic ? OVERRIDABLE_METHODS.static : OVERRIDABLE_METHODS.instance)[typeName];
  return Array.isArray(cfg) && cfg.indexOf(memberName) !== -1;
};

/**
 * @returns `true` iff `linkName` is `tags` on an Issue and the feature flag is on.
 */
exports.isApplicable = function (enclosingEntity, linkName) {
  if (linkName !== 'tags') {return false;}
  if (!enclosingEntity) {return false;}
  const wrapped = enclosingEntity._wrapped;
  if (!wrapped || typeof wrapped.getEntityType !== 'function') {return false;}
  if (wrapped.getEntityType() !== 'Issue') {return false;}
  return LegacyStarShim.isEnabled();
};

/**
 * Builds one synthetic star tag object for `ownerWW`.
 * Exposes the same WatchFolder / IssueTag fields that are accessible in the WORKFLOW scope
 * so that visitors iterating `issue.tags` can safely read those fields without TypeError.
 */
function makeSyntheticStar(ownerWW) {
  const star = {
    // Core identity
    name: 'Star',
    owner: ownerWW,
    // WatchFolder fields (workflow-accessible)
    permittedReadUserGroups: EMPTY_SET,
    permittedReadUsers: EMPTY_SET,
    permittedUpdateUserGroups: EMPTY_SET,
    permittedUpdateUsers: EMPTY_SET,
    pinnedByDefault: false,
    getName: function () { return 'Star'; },
    getShareGroup: function () { return null; },
    getUpdateShareGroup: function () { return null; },
    // IssueTag fields (workflow-accessible)
    permittedTagUsers: EMPTY_SET,
    permittedTagUserGroups: EMPTY_SET,
    isPrivate: true,
    color: null,
    untagOnResolve: false,
    canBeUsedForIssue: function () { return false; },
    canBeUsedForArticle: function () { return false; },
    getId: function () { return null; }
  };
  Object.defineProperty(star, SYNTHETIC_STAR_MARKER, {value: true, enumerable: false});
  return star;
}

function syntheticTags(issueEntity) {
  const javaList = LegacyStarShim.starringUsers(issueEntity._wrapped);
  const stars = [];
  for (let i = 0; i < javaList.size(); i++) {
    const userPew = javaList.get(i);
    const userWW = new entitiesRegistry[userPew.getEntityType()](userPew);
    stars.push(makeSyntheticStar(userWW));
  }
  return stars;
}

/**
 * Returns a view over `base` that merges the synthetic star tags for `issueEntity`.
 * `base` must be a `MutableIterableWW` over the issue's real tags.
 */
exports.decorate = function (base, issueEntity) {
  const view = Object.create(base);

  function readUsage() {
    LegacyStarShim.recordUsage('READ_TAGS');
  }

  view.forEach = function (visitor) {
    let index = 0;
    base.forEach(v => visitor(v, index++, view));
    const stars = syntheticTags(issueEntity);
    if (stars.length > 0) {readUsage();}
    for (const s of stars) {visitor(s, index++, view);}
  };
  view.find = function (visitor) {
    const fromReal = base.find(visitor);
    if (fromReal !== null && fromReal !== undefined) {return fromReal;}
    const stars = syntheticTags(issueEntity);
    for (const s of stars) {
      if (visitor(s)) {
        readUsage();
        return s;
      }
    }
  };
  view.map = function (visitor) {
    const result = [];
    let index = 0;
    base.forEach(v => { result.push(visitor(v, index++, view)); });
    const stars = syntheticTags(issueEntity);
    if (stars.length > 0) {readUsage();}
    for (const s of stars) {result.push(visitor(s, index++, view));}
    return result;
  };
  Object.defineProperty(view, 'size', {
    get: function () {
      return base.size + LegacyStarShim.starringUsers(issueEntity._wrapped).size();
    }
  });
  view.isEmpty = function () {
    if (!base.isEmpty()) {return false;}
    return LegacyStarShim.starringUsers(issueEntity._wrapped).size() === 0;
  };
  view.isNotEmpty = function () {
    if (base.isNotEmpty()) {return true;}
    return LegacyStarShim.starringUsers(issueEntity._wrapped).size() > 0;
  };
  view.has = function (element) {
    if (element !== null && element !== undefined && element[SYNTHETIC_STAR_MARKER]) {
      readUsage();
      return LegacyStarShim.hasStarFor(issueEntity._wrapped, element.owner._wrapped);
    }
    return base.has(element);
  };
  view.add = function (element) {
    if (element !== null && element !== undefined && element[SYNTHETIC_STAR_MARKER]) {
      LegacyStarShim.star(issueEntity._wrapped, element.owner._wrapped);
      LegacyStarShim.recordUsage('TAG_ADD');
      return;
    }
    return base.add(element);
  };
  view.delete = function (element) {
    if (element !== null && element !== undefined && element[SYNTHETIC_STAR_MARKER]) {
      LegacyStarShim.unstar(issueEntity._wrapped, element.owner._wrapped);
      LegacyStarShim.recordUsage('TAG_REMOVE');
      return;
    }
    return base.delete(element);
  };
  view['@@iterator'] = function () {
    const baseIter = base['@@iterator']();
    const stars = syntheticTags(issueEntity);
    let starsRead = false;
    let starIdx = 0;
    return {
      next: function () {
        const r = baseIter.next();
        if (!r.done) {return r;}
        if (starIdx < stars.length) {
          if (!starsRead) { readUsage(); starsRead = true; }
          return {done: false, value: stars[starIdx++]};
        }
        return {done: true, value: null};
      }
    };
  };
  return view;
};

/**
 * Returns a synthetic Set-shaped object carrying one synthetic Star tag for the rule's
 * effective user. Used by the wrappers around `Tag.findByName('Star')` and friends so
 * legacy `issue.tag(Tag.findByName('Star').first())` flows still surface a real user
 * wrapper as the synthetic Star's `owner`.
 */
function syntheticStarSetForCurrentUser() {
  const userPew = LegacyStarShim.currentUserWrapper();
  if (userPew === null) {
    return emptySyntheticTagSet();
  }
  const userWW = new entitiesRegistry[userPew.getEntityType()](userPew);
  const star = makeSyntheticStar(userWW);
  return {
    first: function () { return star; },
    forEach: function (visitor) { visitor(star, 0, this); },
    size: 1,
    isEmpty: function () { return false; },
    isNotEmpty: function () { return true; }
  };
}

function emptySyntheticTagSet() {
  return {
    first: function () { return undefined; },
    forEach: function () {},
    size: 0,
    isEmpty: function () { return true; },
    isNotEmpty: function () { return false; }
  };
}

/**
 * Wraps `Tag.findByName('Star')`, `Tag.findTagByName('Star')`, and the duplicated
 * `IssueTag.findByName('Star')` / `IssueTag.findTagByName('Star')` shims so they return
 * the synthetic Star set/element. Any other tag name falls through to the original.
 */
function decorateTagStaticMethods(target) {
  if (!target) {return;}
  ['findByName', 'findTagByName'].forEach(function (methodName) {
    const original = target[methodName];
    if (typeof original !== 'function') {return;}
    const usageKind = methodName === 'findTagByName' ? 'FIND_TAG_BY_NAME' : 'FIND_BY_NAME';
    Object.defineProperty(target, methodName, {
      enumerable: true,
      configurable: true,
      writable: true,
      value: function (name) {
        if (LegacyStarShim.isEnabled() && LegacyStarShim.matchesStarName(name)) {
          LegacyStarShim.recordUsage(usageKind);
          const set = syntheticStarSetForCurrentUser();
          return methodName === 'findTagByName' ? set.first() : set;
        }
        return original.apply(this, arguments);
      }
    });
  });
}

/**
 * Wraps `Issue.prototype.tag` / `Issue.prototype.untag` so that synthetic Star elements
 * (those carrying SYNTHETIC_STAR_MARKER, e.g. from the decorated `Tag.findByName`) route
 * to `LegacyStarShim.star` / `unstar`. Real tag elements still fall through unchanged.
 */
function decorateIssueProtoMethods(issueProto) {
  if (!issueProto) {return;}
  const originalTag = issueProto.tag;
  if (typeof originalTag === 'function') {
    Object.defineProperty(issueProto, 'tag', {
      enumerable: true,
      configurable: true,
      writable: true,
      value: function (tag) {
        if (tag !== null && tag !== undefined && tag[SYNTHETIC_STAR_MARKER]) {
          LegacyStarShim.star(this._wrapped, tag.owner._wrapped);
          LegacyStarShim.recordUsage('ISSUE_TAG_METHOD');
          return;
        }
        return originalTag.apply(this, arguments);
      }
    });
  }
  const originalUntag = issueProto.untag;
  if (typeof originalUntag === 'function') {
    Object.defineProperty(issueProto, 'untag', {
      enumerable: true,
      configurable: true,
      writable: true,
      value: function (tag) {
        if (tag !== null && tag !== undefined && tag[SYNTHETIC_STAR_MARKER]) {
          LegacyStarShim.unstar(this._wrapped, tag.owner._wrapped);
          LegacyStarShim.recordUsage('ISSUE_UNTAG_METHOD');
          return;
        }
        return originalUntag.apply(this, arguments);
      }
    });
  }
  // hasTag and addTag still go through their Kotlin @ApiMethod implementations (which
  // route Star through `LegacyStarTagCompatHelper`). The wrappers here only attach
  // telemetry for the "Star" case so the statistics interface sees every legacy idiom.
  const originalHasTag = issueProto.hasTag;
  if (typeof originalHasTag === 'function') {
    Object.defineProperty(issueProto, 'hasTag', {
      enumerable: true,
      configurable: true,
      writable: true,
      value: function (name) {
        const result = originalHasTag.apply(this, arguments);
        if (result && LegacyStarShim.isEnabled() && LegacyStarShim.matchesStarName(name)) {
          LegacyStarShim.recordUsage('PREREQUISITE_HAS_TAG');
        }
        return result;
      }
    });
  }
  const originalAddTag = issueProto.addTag;
  if (typeof originalAddTag === 'function') {
    Object.defineProperty(issueProto, 'addTag', {
      enumerable: true,
      configurable: true,
      writable: true,
      value: function (name) {
        if (LegacyStarShim.isEnabled() && LegacyStarShim.matchesStarName(name)) {
          LegacyStarShim.recordUsage('ADD_TAG_METHOD');
        }
        return originalAddTag.apply(this, arguments);
      }
    });
  }
}

/**
 * Called from entities.js after `yTypes.get().forEach(handleClass)` and after publishing
 * to `exports`. Decorates the static and instance methods that legacy "Star as a tag"
 * idioms relied on.
 */
exports.decorateAfterRegistration = function (exportsObject) {
  if (!entitiesRegistry) {return;}
  decorateTagStaticMethods(entitiesRegistry['Tag']);
  // `exports.IssueTag` is a separate object literal in entities.js delegating to Tag;
  // re-decorate so legacy callers that use entities.IssueTag.findByName see synthetic Stars.
  if (exportsObject && exportsObject['IssueTag']) {
    decorateTagStaticMethods(exportsObject['IssueTag']);
  }
  if (entitiesRegistry['Issue']) {
    decorateIssueProtoMethods(entitiesRegistry['Issue'].prototype);
  }
};
